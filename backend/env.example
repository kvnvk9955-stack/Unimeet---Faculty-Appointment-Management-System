# ─────────────────────────────────────────────
# Unimeet Backend Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas Connection String)
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/unimeet?retryWrites=true&w=majority

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_64_char_hex_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_64_char_hex_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=12
ADMIN_SECRET=your_admin_registration_secret
MAX_SESSIONS_PER_USER=5
TRUST_PROXY=false

# Email (Gmail App Password: Google Account → Security → App Passwords)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_digit_app_password
EMAIL_FROM=Unimeet <noreply@unimeet.app>

# Frontend URL (CRITICAL: Set this to your Vercel deployment URL in production)
# Examples:
#   Development: http://localhost:8080
#   Production:  https://unimeet.vercel.app
CLIENT_URL=http://localhost:8080
